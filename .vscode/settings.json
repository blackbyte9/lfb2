{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "prettier.requireConfig": true,
  "cSpell.words": [
    "Ausleih",
    "Ausleihliste",
    "Ausleihverlauf",
    "cuid",
    "datasource",
    "firstname",
    "Jahrgangsdaten",
    "Jahrgangshistorie",
    "Kodierungsfehler",
    "Metadatum",
    "Namenkodierung",
    "Parserlogik",
    "postgresql",
    "rollenbasierte",
    "Rückgabehistorie",
    "samesite",
    "Verfügbarkeitsinformationen",
    "Verlaufsdaten"
  ],
  "cSpell.ignorePaths": [
    "**/*config.{js,cjs,mjs,ts,json,yml,yaml}",
    "**/tsconfig*.json",
    "**/.eslintrc*",
    "**/.prettierrc*",
    "**/components.json",
    "**/.vscode/settings.json"
  ],
  "WillLuke.nextjs.addTypesOnSave": true,
  "WillLuke.nextjs.hasPrompted": true
}
